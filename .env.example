# Django API base URL
VITE_API_BASE_URL=http://127.0.0.1:8000

# Robot dashboard API (pose, YOLO stream, WebSocket on port + 1)
VITE_ROBOT_API_BASE_URL=http://127.0.0.1:8080

# Google OAuth client ID (Web application) from Google Cloud Console.
# Authorized JavaScript origins: http://localhost:5173
# Authorized redirect URIs are not required for the GIS popup flow.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
